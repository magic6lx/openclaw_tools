{
  "name": "openclaw-launcher",
  "version": "1.0.0",
  "description": "OpenClaw Launcher - 本地代理服务",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node src/index.js",
    "build": "pkg src/index.js --targets node18-win-x64 --output dist_new/openclaw-launcher.exe"
  },
  "build": {
    "assets": "assets/**/*",
    "targets": [
      {
        "target": "node18-win-x64",
        "arch": ["x64"]
      }
    ],
    "output": "dist_new"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "uuid": "^9.0.0"
  },
  "optionalDependencies": {
    "pkg": "^5.8.1"
  }
}
