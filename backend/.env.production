# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=openclaw_config
DB_USER=root
DB_PASSWORD=your_db_password_here

# JWT密钥（生产环境请使用复杂随机字符串）
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# 运行监控配置
MAX_NODE_PROCESSES=30

# 服务器端口
PORT=3000

# 前端API地址（反向代理用）
API_BASE_URL=http://localhost:3000
